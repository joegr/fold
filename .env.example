# ──────────────────────────────────────────────────────────
# Circuit Card Simulator – Environment Configuration
# Copy this file to .env and adjust values as needed.
# ──────────────────────────────────────────────────────────

# Flask
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=0

# Flask secret key (REQUIRED - no fallback)
# Used to sign session cookies AND (via HKDF) to derive the algorithm-
# parameter signing key. Must be the same across all gunicorn workers.
# Generate: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_C_IMPORT_OS_PRINT_OS_URANDOM_32_HEX

# CORS – comma-separated list of allowed origins (REQUIRED - no wildcard)
# SECURITY: Must explicitly list all allowed origins. No '*' wildcard allowed.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# API key authentication (REQUIRED).
# Used for SERVER-TO-SERVER calls to the /api/* endpoints and for the main
# backend to authenticate itself to the PQC sidecar. The browser frontend does
# NOT use this key — it uses a session cookie minted by /api/session.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_C_IMPORT_SECRETS_PRINT_SECRETS_TOKEN_URLSAFE_32

# Session cookie: set to 0 only when developing over plain HTTP on localhost.
# In production (HTTPS), leave at 1.
SESSION_COOKIE_SECURE=1

# Request / resource limits
MAX_CARDS=20
MAX_NODES_PER_CARD=16
MAX_REQUEST_SIZE=1048576
MAX_HISTORY_RECORDS=200
MAX_HISTORY_USERS=1000
PQC_MAX_PROXY_BODY=262144

# ──────────────────────────────────────────────────────────
# Reverse-proxy / rate-limiter configuration
# ──────────────────────────────────────────────────────────

# Number of reverse-proxy hops in front of this app (0 if direct-to-internet).
# When > 0, X-Forwarded-For / X-Forwarded-Proto are honored. Set precisely to
# the number of trusted hops — over-trusting lets clients spoof their source IP
# and bypass rate limits.
TRUSTED_PROXY_HOPS=0

# Redis URL for Flask-Limiter shared storage (recommended under gunicorn with
# multiple workers). Without this, each worker keeps its own in-memory
# counters, so effective rate limits are multiplied by the worker count.
#
# The docker-compose stack provides this automatically via the `redis` service
# and overrides REDIS_URL in the `app` / `pqc` / `dev` services, so you do NOT
# need to set this for compose-based deployments. Set it here only when
# running the Python process directly against an external Redis (e.g. for
# local, non-Docker development).
# Example: redis://localhost:6379/0
REDIS_URL=

# scrypt cost (classical CircuitEncryption KDF). 2**15 ≈ 32 MB memory / ~100 ms
# per derivation on modern hardware. Raise to 2**17 for high-value data.
SCRYPT_N=32768

# Gunicorn (production only, via Docker)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30

# ──────────────────────────────────────────────────────────
# Post-Quantum Cryptography (PQC) service
# ──────────────────────────────────────────────────────────

# PQC sidecar port
PQC_PORT=5001

# Internal URL used by the main app to proxy PQC requests.
# SECURITY: Only loopback / private-IP addresses or hostnames in
# PQC_ALLOWED_HOSTNAMES below are accepted. Validated via ipaddress.is_private.
PQC_SERVICE_URL=http://pqc:5001

# Explicit allowlist of internal service hostnames that PQC_SERVICE_URL may
# use (comma-separated). Keep this tight.
PQC_ALLOWED_HOSTNAMES=pqc,localhost
