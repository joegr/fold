# ──────────────────────────────────────────────────────────
# Circuit Card Simulator – Environment Configuration
# Copy this file to .env and adjust values as needed.
# ──────────────────────────────────────────────────────────

# Flask
PORT=5000
FLASK_DEBUG=0

# Flask secret key (auto-generated if not set)
# Generate: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=

# CORS – comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# API key authentication (leave empty to disable)
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Request / resource limits
MAX_CARDS=20
MAX_NODES_PER_CARD=16
MAX_REQUEST_SIZE=1048576
MAX_HISTORY_RECORDS=200
