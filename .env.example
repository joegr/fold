# ──────────────────────────────────────────────────────────
# Circuit Card Simulator – Environment Configuration
# Copy this file to .env and adjust values as needed.
# ──────────────────────────────────────────────────────────

# Flask
PORT=5000
FLASK_DEBUG=0

# Flask secret key (REQUIRED - no fallback)
# SECURITY: Must be set explicitly. Each worker needs the same key.
# Generate: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_C_IMPORT_OS_PRINT_OS_URANDOM_32_HEX

# CORS – comma-separated list of allowed origins (REQUIRED - no wildcard)
# SECURITY: Must explicitly list all allowed origins. No '*' wildcard allowed.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# API key authentication (REQUIRED - no fallback)
# SECURITY: Must be set explicitly. All API endpoints require this key.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_C_IMPORT_SECRETS_PRINT_SECRETS_TOKEN_URLSAFE_32

# Request / resource limits
MAX_CARDS=20
MAX_NODES_PER_CARD=16
MAX_REQUEST_SIZE=1048576
MAX_HISTORY_RECORDS=200

# Gunicorn (production only, via Docker)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30

# ──────────────────────────────────────────────────────────
# Post-Quantum Cryptography (PQC) service
# ──────────────────────────────────────────────────────────

# PQC sidecar port
PQC_PORT=5001

# Internal URL used by the main app to proxy PQC requests
# SECURITY: Only internal addresses allowed (localhost, 127.0.0.1, 10.x, 172.16-31.x, 192.168.x)
# Default is internal Docker network hostname
PQC_SERVICE_URL=http://pqc:5001

# Frontend toggle: set to "1" to enable PQ mode in the React UI
REACT_APP_PQC_ENABLED=1
